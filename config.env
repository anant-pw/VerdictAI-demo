# ============================================================
# VerdictAI — config.env.template
# Copy this to config.env and fill in your keys.
# NEVER commit config.env to Git — it is in .gitignore
# ============================================================

# ── Primary LLM (Model Under Test) ──────────────────────────
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
# Free tier: 14,400 req/day | 30 req/min
# Get key: https://console.groq.com

# ── Judge Provider 2: SambaNova (free, no credit card) ──────
SAMBANOVA_API_KEY=
SAMBANOVA_MODEL=Meta-Llama-3.3-70B-Instruct
# Get key: https://cloud.sambanova.ai

# ── Judge Provider 3: Cerebras  ────────
CEREBRAS_API_KEY=
CEREBRAS_MODEL=llama3.1-8b
# Get key: https://cloud.cerebras.ai

# ── Hallucination Detector model ────────────────────────────
# Uses GROQ_API_KEY above — no separate key needed

# ── Jira Integration (optional) ─────────────────────────────
JIRA_URL=https://yourid.atlassian.net
JIRA_EMAIL=
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=
JIRA_ISSUE_TYPE=Task

# ── GitHub (optional — for CI badge) ────────────────────────
GITHUB_TOKEN=
GITHUB_REPO=

# ── LangSmith Tracing (optional) ────────────────────────────
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=

# ── Gemini (optional — swap in if you prefer over SambaNova) ─
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
# Get key: https://aistudio.google.com
